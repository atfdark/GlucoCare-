generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                    String    @id @default(uuid())
  name                  String
  email                 String    @unique
  phone                 String
  role                  String    // "patient", "doctor", or "admin"
  isActive              Boolean   @default(true)
  password              String
  specialization        String?   // doctor only
  medicalRegistrationNo String?   // doctor only
  hospitalName          String?   // doctor only
  age                   Int?      // patient only
  gender                String?   // patient only
  createdAt             DateTime  @default(now())

  patientProfile        PatientProfile?
  doctorProfile         DoctorProfile?
  glucoseReadings       GlucoseReading[]
  alerts               Alert[]
  prescriptions         Prescription[]   @relation("PatientPrescriptions")
  prescriptionsGiven    Prescription[]   @relation("DoctorPrescriptions")
  reminders             Reminder[]       @relation("PatientReminders")
  remindersCreated      Reminder[]       @relation("DoctorReminders")
  healthMetrics         HealthMetric[]

  doctorAssignments     DoctorPatientAssignment[] @relation("DoctorAssignments")
  patientAssignments    DoctorPatientAssignment[] @relation("PatientAssignments")

  actorAuditEvents      AuditEvent[] @relation("AuditActor")
  targetAuditEvents     AuditEvent[] @relation("AuditTarget")
}

model PatientProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  age       Int?
  gender    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model DoctorProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  specialization        String?
  medicalRegistrationNo String?  @unique
  hospitalName          String?
  createdAt             DateTime @default(now())

  user                  User     @relation(fields: [userId], references: [id])
}

model DoctorPatientAssignment {
  id         String   @id @default(uuid())
  doctorId   String
  patientId  String
  createdAt  DateTime @default(now())

  doctor     User     @relation("DoctorAssignments", fields: [doctorId], references: [id])
  patient    User     @relation("PatientAssignments", fields: [patientId], references: [id])

  @@unique([doctorId, patientId])
}

model GlucoseReading {
  id        String   @id @default(uuid())
  patientId String
  value     Float
  type      String   // "fasting" or "post-meal"
  createdAt DateTime @default(now())

  patient   User     @relation(fields: [patientId], references: [id])
}

model Alert {
  id         String   @id @default(uuid())
  patientId  String
  alertType  String
  severity   String
  message    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  patient    User     @relation(fields: [patientId], references: [id])
}

model Prescription {
  id        String   @id @default(uuid())
  patientId String
  doctorId  String
  medicine  String
  dosage    String
  duration  String
  notes     String?
  createdAt DateTime @default(now())

  patient   User     @relation("PatientPrescriptions", fields: [patientId], references: [id])
  doctor    User     @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
}

model Reminder {
  id         String   @id @default(uuid())
  patientId  String
  doctorId   String?
  title      String
  message    String
  remindAt   DateTime
  isDone     Boolean  @default(false)
  createdAt  DateTime @default(now())

  patient    User     @relation("PatientReminders", fields: [patientId], references: [id])
  doctor     User?    @relation("DoctorReminders", fields: [doctorId], references: [id])

  @@index([patientId, remindAt])
  @@index([doctorId, createdAt])
}

model HealthMetric {
  id         String   @id @default(uuid())
  patientId  String
  weight     Float
  systolic   Int
  diastolic  Int
  hba1c      Float
  createdAt  DateTime @default(now())

  patient    User     @relation(fields: [patientId], references: [id])

  @@index([patientId, createdAt])
}

model AuditEvent {
  id          String   @id @default(uuid())
  actorUserId String?
  targetUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  target      User?    @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([createdAt])
  @@index([actorUserId])
  @@index([targetUserId])
}
